{#
  Server Template - Fetch-based loading for large datasets (1M+ points)

  Loads data via HTTP fetch instead of inline base64.
  Color columns are loaded lazily on demand.

  Usage:
    viz.serve(port=8050)
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: {{ background_color }};
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    #canvas {
      width: 100vw;
      height: 100vh;
      display: block;
    }
    #title {
      position: fixed;
      top: 12px;
      left: 12px;
      padding: 6px 10px;
      border-radius: 6px;
      background: rgba(0, 0, 0, 0.4);
      font-size: 14px;
      letter-spacing: 0.4px;
      z-index: 120;
    }
    #controls {
      position: fixed;
      top: 12px;
      right: 12px;
      padding: 8px 10px;
      background: #000;
      border-radius: 6px;
      font-size: 13px;
      color: #fff;
      min-width: 160px;
      z-index: 120;
    }
    #controls label {
      font-size: 12px;
      color: #fff;
      display: block;
      margin-bottom: 4px;
    }
    #controls select {
      width: 100%;
      padding: 6px 8px;
      border-radius: 4px;
      border: 1px solid #fff;
      background: #000;
      color: #fff;
    }
    #legend {
      position: fixed;
      bottom: 12px;
      right: 12px;
      padding: 10px 12px;
      background: #000;
      border: 1px solid #333;
      border-radius: 6px;
      font-size: 12px;
      color: #fff;
      min-width: 160px;
      max-width: 240px;
      max-height: 240px;
      overflow: auto;
      z-index: 120;
    }
    #legend.hidden { display: none; }
    #legend-title { font-weight: 600; margin-bottom: 6px; }
    .legend-gradient { height: 10px; border-radius: 4px; border: 1px solid #fff; }
    .legend-range { display: flex; justify-content: space-between; font-size: 11px; margin-top: 4px; }
    .legend-item { display: flex; align-items: center; gap: 8px; margin: 2px 0; }
    .legend-swatch { width: 12px; height: 12px; border-radius: 3px; border: 1px solid #fff; }
    #tooltip {
      position: fixed;
      pointer-events: none;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid #333;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 12px;
      color: #e0e0e0;
      width: 240px;
      display: none;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      z-index: 130;
    }
    #tooltip.visible { display: block; }
    #tooltip .label { font-weight: 700; margin-bottom: 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #tooltip .row { display: flex; justify-content: space-between; gap: 12px; margin: 2px 0; }
    #tooltip .key { color: #9ca3af; flex-shrink: 0; }
    #tooltip .value { color: #e5e7eb; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
    #loading {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: {{ background_color }};
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    #loading.hidden { display: none; }
    #loading-text { font-size: 18px; margin-bottom: 20px; }
    #progress-bar { width: 300px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; overflow: hidden; }
    #progress-fill { height: 100%; background: #4a9eff; width: 0%; transition: width 0.2s; }
    #progress-text { margin-top: 10px; font-size: 14px; color: #9ca3af; }

    /* Card stack - pinned cards from single clicks */
    #card-stack {
      position: fixed;
      bottom: 12px;
      left: 12px;
      z-index: 100;
    }
    #card-stack.hidden { display: none; }
    .card {
      width: 240px;
      background: rgba(0, 0, 0, 0.9);
      border: 1px solid #444;
      border-radius: 8px;
      padding: 12px;
      color: #e0e0e0;
      font-size: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
      padding-bottom: 8px;
      border-bottom: 1px solid #333;
    }
    .card-nav {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #9ca3af;
    }
    .card-nav button {
      background: #333;
      border: 1px solid #555;
      color: #fff;
      width: 22px;
      height: 22px;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      padding: 0;
    }
    .card-nav button:hover { background: #444; }
    .card-nav button:disabled { opacity: 0.3; cursor: not-allowed; }
    .card-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 18px;
      cursor: pointer;
      padding: 0 0 0 8px;
      line-height: 1;
    }
    .card-close:hover { color: #fff; }
    .card-minimize {
      background: transparent;
      border: none;
      color: #666;
      font-size: 14px;
      cursor: pointer;
      padding: 0 4px;
      line-height: 1;
    }
    .card-minimize:hover { color: #fff; }
    .card.minimized .card-body { display: none; }
    .card.minimized { padding: 8px 12px; }
    .card.minimized .card-header { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .card-body { }
    .card-label {
      font-weight: 700;
      margin-bottom: 8px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
    }
    .card-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      text-align: right;
    }
    .card-copy-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
      background: #1a1a1a;
      padding: 6px 8px;
      border-radius: 4px;
    }
    .card-copy-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-copy-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      font-family: monospace;
      font-size: 11px;
    }
    .card-copy-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 3px 8px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 10px;
      flex-shrink: 0;
      font-weight: 500;
    }
    .card-copy-btn:hover { background: #3a8eef; }
    .card-copy-btn.copied { background: #22c55e; }
    /* Structure rendering for SMILES tooltips and cards */
    #tooltip .structure-container {
      width: 240px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #tooltip .structure-container.hidden { display: none; }
    #tooltip #structure-svg { width: 240px; height: 200px; }
    .card .card-structure-container {
      display: flex;
      width: 216px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-bottom: 8px;
      align-items: center;
      justify-content: center;
    }
    .card .card-structure-container.hidden { display: none; }
    .card #card-structure-svg { width: 216px; height: 200px; }

    /* Search panel - top left below title */
    #search-panel {
      position: fixed;
      top: 52px;
      left: 12px;
      padding: 8px 10px;
      background: #000;
      border-radius: 6px;
      font-size: 12px;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 200px;
      z-index: 90;
    }
    #search-panel label { font-size: 11px; color: #9ca3af; }
    #search-panel select, #search-panel input[type="text"] {
      width: 100%;
      padding: 5px 8px;
      border-radius: 4px;
      border: 1px solid #555;
      background: #1a1a1a;
      color: #fff;
      font-size: 12px;
      box-sizing: border-box;
    }
    #search-panel .search-row {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    #search-panel .search-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 5px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      white-space: nowrap;
    }
    #search-panel .search-btn:hover { background: #3a8eef; }
    #search-panel .search-btn.clear { background: #333; border: 1px solid #555; }
    #search-panel .search-btn.clear:hover { background: #444; }
    #search-panel .partial-match {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      cursor: pointer;
    }
    #search-results {
      font-size: 11px;
      color: #9ca3af;
      min-height: 16px;
    }

    /* Export panel - for multi-select */
    #export-panel {
      position: fixed;
      bottom: 12px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0, 0, 0, 0.9);
      border: 1px solid #444;
      border-radius: 8px;
      padding: 12px 16px;
      color: #e0e0e0;
      font-size: 12px;
      z-index: 100;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
      min-width: 280px;
    }
    #export-panel.hidden { display: none; }
    .export-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .export-title { font-weight: 600; font-size: 13px; }
    .export-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 16px;
      cursor: pointer;
      padding: 0;
    }
    .export-close:hover { color: #fff; }
    .export-columns {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 12px;
      margin-bottom: 12px;
      padding: 8px;
      background: #1a1a1a;
      border-radius: 4px;
      max-width: 400px;
    }
    .export-columns label {
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      font-size: 11px;
    }
    .export-columns input[type="checkbox"] { cursor: pointer; }
    .export-actions {
      display: flex;
      gap: 8px;
    }
    .export-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 6px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }
    .export-btn:hover { background: #3a8eef; }
    .export-btn.secondary {
      background: #333;
      border: 1px solid #555;
    }
    .export-btn.secondary:hover { background: #444; }
  </style>
</head>
<body>
  <div id="loading">
    <div id="loading-text">Loading visualization...</div>
    <div id="progress-bar"><div id="progress-fill"></div></div>
    <div id="progress-text">Initializing...</div>
  </div>

  <div id="title">{{ title }}</div>
  <div id="controls">
    <label for="color-select">Color By Layout</label>
    <select id="color-select"></select>
    <label style="margin-top:6px;cursor:pointer;"><input type="checkbox" id="edge-toggle" checked style="cursor:pointer;"> Show edges</label>
  </div>
  <canvas id="canvas"></canvas>
  <div id="tooltip">
    <div class="label" id="tooltip-label"></div>
    <div id="tooltip-content"></div>
    <div class="structure-container hidden" id="tooltip-structure"></div>
  </div>
  <div id="legend" class="hidden">
    <div id="legend-title"></div>
    <div id="legend-content"></div>
  </div>
  <div id="card-stack" class="hidden"></div>
  <div id="export-panel" class="hidden">
    <div class="export-header">
      <span class="export-title" id="export-title">0 points selected</span>
      <button class="export-close" id="export-close">&times;</button>
    </div>
    <div class="export-columns" id="export-columns"></div>
    <div class="export-actions">
      <button class="export-btn" id="export-csv">Export CSV</button>
      <button class="export-btn secondary" id="export-tsv">Export TSV</button>
      <button class="export-btn secondary" id="export-clear">Clear</button>
    </div>
  </div>
  <div id="search-panel">
    <label for="search-column">Search in column</label>
    <select id="search-column"></select>
    <label for="search-input">Search query</label>
    <div class="search-row">
      <input type="text" id="search-input" placeholder="Enter search term...">
      <button class="search-btn" id="search-btn">Search</button>
    </div>
    <div class="search-row">
      <label class="partial-match">
        <input type="checkbox" id="partial-match"> Partial match
      </label>
      <button class="search-btn clear" id="clear-search">Clear</button>
    </div>
    <div id="search-results"></div>
  </div>

  <!-- fflate for decompression -->
  <script src="https://cdn.jsdelivr.net/npm/fflate@0.8.2/umd/index.min.js"></script>
  <!-- SmilesDrawer for molecule rendering -->
  <script src="https://unpkg.com/smiles-drawer@2.1.7/dist/smiles-drawer.min.js"></script>

  <script type="module">
    const decode = (b64) => atob(b64);
    const mkModule = (code) =>
      URL.createObjectURL(new Blob([code], { type: 'application/javascript' }));

    const reglSource = decode("{{ runtime_regl }}");
    const pubSubSource = decode("{{ runtime_pubsub }}");
    const scatterSourceRaw = decode("{{ runtime_scatterplot }}");

    const reglModuleSource = `
const module = { exports: {} };
const exports = module.exports;
const globalThisRef = typeof globalThis !== 'undefined' ? globalThis : window;
${reglSource}
export default module.exports || globalThisRef.createREGL || createREGL;
`;
    const reglUrl = mkModule(reglModuleSource);
    const pubSubUrl = mkModule(pubSubSource);
    const scatterSource = scatterSourceRaw
      .replace(/from "regl"/g, 'from "' + reglUrl + '"')
      .replace(/from 'regl'/g, 'from "' + reglUrl + '"')
      .replace(/from "pub-sub-es"/g, 'from "' + pubSubUrl + '"')
      .replace(/from 'pub-sub-es'/g, 'from "' + pubSubUrl + '"');
    const scatterUrl = mkModule(scatterSource);

    const runtime = `
import createScatterplot from '${scatterUrl}';
import createREGL from '${reglUrl}';

const loading = document.getElementById('loading');
const progressFill = document.getElementById('progress-fill');
const progressText = document.getElementById('progress-text');

function updateProgress(percent, text) {
  progressFill.style.width = percent + '%';
  progressText.textContent = text;
}

// Decode gzip-compressed binary data using fflate
function decodeGzipBuffer(buffer, dtype) {
  const bytes = new Uint8Array(buffer);
  const decompressed = fflate.gunzipSync(bytes);
  switch (dtype) {
    case 'uint16': return new Uint16Array(decompressed.buffer);
    case 'uint32': return new Uint32Array(decompressed.buffer);
    case 'float32': return new Float32Array(decompressed.buffer);
    case 'int32': return new Int32Array(decompressed.buffer);
    default: throw new Error('Unknown dtype: ' + dtype);
  }
}

function dequantizeCoords(quantized, bits = 16) {
  const n = quantized.length / 2;
  const maxVal = bits === 16 ? 65535 : 4294967295;
  const scale = 2.0 / maxVal;
  const x = new Float32Array(n);
  const y = new Float32Array(n);
  for (let i = 0; i < n; i++) {
    x[i] = quantized[i * 2] * scale - 1.0;
    y[i] = quantized[i * 2 + 1] * scale - 1.0;
  }
  return { x, y };
}

// ============================================
// Fetch Data from Server
// ============================================

updateProgress(5, 'Fetching metadata...');
const metadata = await fetch('/metadata.json').then(r => r.json());

const colormaps = metadata.colormaps || {};
const layoutOptions = metadata.layoutOptions || [];
const labelOptions = metadata.labelOptions || [];
const columnMeta = metadata.columns || {};
const nEdges = metadata.nEdges || 0;

updateProgress(10, 'Fetching coordinates...');
const coordsBuffer = await fetch('/coords.bin').then(r => r.arrayBuffer());
const coordDtype = metadata.coordDtype || 'uint16';
const coordBits = coordDtype === 'uint16' ? 16 : 32;
const quantizedCoords = decodeGzipBuffer(coordsBuffer, coordDtype);
const { x, y } = dequantizeCoords(quantizedCoords, coordBits);
const n = x.length;
const N = n;

updateProgress(30, 'Preparing visualization...');
const hasEdges = nEdges > 0;
const parsedEdgeWidth = Number(metadata.edgeWidth);
const edgeWidth = Number.isFinite(parsedEdgeWidth) && parsedEdgeWidth > 0 ? parsedEdgeWidth : 2;
const edgeStrokeStyle = metadata.edgeStrokeStyle || 'rgba(0, 0, 0, 0.5)';

updateProgress(40, 'Fetching columns...');

// Load initial color layout column eagerly, others lazily
const columns = {};
const columnNames = Object.keys(columnMeta);
const initialColor = layoutOptions[0] || '';

// Load string columns from metadata (they're embedded)
for (const name of columnNames) {
  const meta = columnMeta[name];
  if (meta.dtype === 'string' && Array.isArray(meta.values)) {
    columns[name] = {
      values: meta.values,
      dtype: 'string',
      role: meta.role,
      colormap: meta.colormap,
    };
  }
}

// Fetch a binary column from the server
async function fetchColumn(name) {
  if (columns[name]) return columns[name];
  const meta = columnMeta[name];
  if (!meta) return null;
  if (meta.dtype === 'string') return columns[name] || null;

  const resp = await fetch('/col_' + encodeURIComponent(name) + '.bin');
  if (!resp.ok) return null;
  const buffer = await resp.arrayBuffer();
  const decoded = decodeGzipBuffer(buffer, meta.dtype);

  if (meta.dictionary) {
    columns[name] = {
      values: Array.from(decoded).map(i => meta.dictionary[i]),
      dtype: 'categorical',
      role: meta.role,
      colormap: meta.colormap,
    };
  } else {
    columns[name] = {
      values: decoded,
      dtype: meta.dtype === 'float32' ? 'continuous' : meta.dtype,
      role: meta.role,
      colormap: meta.colormap,
    };
  }
  return columns[name];
}

// Pre-fetch the initial color column and all label columns
const fetchPromises = [];
if (initialColor) fetchPromises.push(fetchColumn(initialColor));
for (const name of labelOptions) {
  fetchPromises.push(fetchColumn(name));
}
await Promise.all(fetchPromises);

updateProgress(80, 'Initializing visualization...');

// ============================================
// Visualization Setup
// ============================================

const canvas = document.getElementById('canvas');
const colorSelect = document.getElementById('color-select');
const tooltip = document.getElementById('tooltip');
const tooltipLabel = document.getElementById('tooltip-label');
const tooltipContent = document.getElementById('tooltip-content');
const legend = document.getElementById('legend');
const legendTitle = document.getElementById('legend-title');
const legendContent = document.getElementById('legend-content');

function createLinearScale(initialDomain, initialRange) {
  let d0 = initialDomain[0], d1 = initialDomain[1];
  let r0 = initialRange[0], r1 = initialRange[1];
  const scale = (value) => {
    const denom = d1 - d0;
    if (denom === 0) return r0;
    return r0 + ((value - d0) / denom) * (r1 - r0);
  };
  scale.domain = (nd) => { if (nd === undefined) return [d0,d1]; d0=nd[0]; d1=nd[1]; return scale; };
  scale.range = (nr) => { if (nr === undefined) return [r0,r1]; r0=nr[0]; r1=nr[1]; return scale; };
  return scale;
}

const edgeXScale = createLinearScale([-1, 1], [0, canvas.clientWidth || window.innerWidth]);
const edgeYScale = createLinearScale([-1, 1], [canvas.clientHeight || window.innerHeight, 0]);

const fallbackPointColor = metadata.pointColor || '#4a9eff';

const scatterplot = createScatterplot({
  canvas,
  width: canvas.clientWidth || window.innerWidth,
  height: canvas.clientHeight || window.innerHeight,
  pointSize: metadata.pointSize || 4,
  pointSizeSelected: 8,
  opacity: metadata.opacity ?? 0.85,
  opacityInactiveScale: 0.5,
  backgroundColor: metadata.backgroundColor || [0, 0, 0, 1],
  pointColor: fallbackPointColor,
  pointOutlineWidth: 2,
  colorBy: null,
  lassoInitiator: false,
  xScale: edgeXScale,
  yScale: edgeYScale,
  performanceMode: N > 500000,
});

const zeroArray = new Float32Array(n);
const NAN_FALLBACK_COLOR = '#000000';

// === WebGL Edge Rendering ===
// Edges rendered via regl on a separate WebGL canvas (GPU-accelerated).
// For N > 1M, edges default to OFF and load lazily on first toggle.
let edgeNeedsRedraw = false;
let edgesVisible = hasEdges && N <= 1_000_000;
let edgesLoaded = false;
let edgeRegl = null;
let drawEdgesCmd = null;
let edgeCanvas = null;

function parseEdgeColor(str) {
  const m = str.match(/rgba?\\(\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*(?:,\\s*([\\d.]+))?\\s*\\)/);
  if (m) return [+m[1]/255, +m[2]/255, +m[3]/255, m[4] !== undefined ? +m[4] : 1];
  return [0, 0, 0, 0.5];
}
const edgeColor = parseEdgeColor(edgeStrokeStyle);

const edgeToggle = document.getElementById('edge-toggle');
edgeToggle.checked = edgesVisible;

if (hasEdges) {
  canvas.style.position = 'fixed';
  canvas.style.top = '0';
  canvas.style.left = '0';
  canvas.style.zIndex = '2';

  edgeCanvas = document.createElement('canvas');
  edgeCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:1;';
  canvas.parentNode.insertBefore(edgeCanvas, canvas);

  function resizeEdgeCanvas() {
    const dpr = window.devicePixelRatio || 1;
    edgeCanvas.width = window.innerWidth * dpr;
    edgeCanvas.height = window.innerHeight * dpr;
    if (edgeRegl) edgeRegl.poll();
    edgeNeedsRedraw = true;
  }
  resizeEdgeCanvas();
}

async function loadEdges() {
  if (edgesLoaded || !hasEdges) return;

  const buf = await fetch('/edges.bin').then(r => r.arrayBuffer());
  const raw = decodeGzipBuffer(buf, 'uint32');
  const eS = raw.subarray(0, nEdges);
  const eT = raw.subarray(nEdges, 2 * nEdges);

  // Interleaved position buffer from point coordinates
  const positions = new Float32Array(n * 2);
  for (let i = 0; i < n; i++) {
    positions[i * 2] = x[i];
    positions[i * 2 + 1] = y[i];
  }

  // Element index buffer: pairs of vertex indices per edge
  const elements = new Uint32Array(nEdges * 2);
  for (let i = 0; i < nEdges; i++) {
    elements[i * 2] = eS[i];
    elements[i * 2 + 1] = eT[i];
  }

  edgeRegl = createREGL({
    canvas: edgeCanvas,
    extensions: ['OES_element_index_uint'],
    attributes: { alpha: true, premultipliedAlpha: false, antialias: true },
  });

  const vertSrc = 'precision highp float; attribute vec2 position; uniform vec2 u_scale; uniform vec2 u_offset; void main() { gl_Position = vec4(position * u_scale + u_offset, 0.0, 1.0); }';
  const fragSrc = 'precision mediump float; uniform vec4 u_color; void main() { gl_FragColor = u_color; }';

  drawEdgesCmd = edgeRegl({
    vert: vertSrc,
    frag: fragSrc,
    attributes: {
      position: { buffer: edgeRegl.buffer(positions), size: 2 },
    },
    elements: edgeRegl.elements({ data: elements, primitive: 'lines', type: 'uint32' }),
    uniforms: {
      u_scale: edgeRegl.prop('scale'),
      u_offset: edgeRegl.prop('offset'),
      u_color: edgeRegl.prop('color'),
    },
    blend: {
      enable: true,
      func: { srcRGB: 'src alpha', srcAlpha: 1, dstRGB: 'one minus src alpha', dstAlpha: 1 },
    },
    depth: { enable: false },
  });

  edgesLoaded = true;
  edgeNeedsRedraw = true;
}

function renderEdges() {
  if (!edgesLoaded || !edgesVisible || !edgeRegl) return;
  edgeRegl.poll();
  edgeRegl.clear({ color: [0, 0, 0, 0] });

  // Derive data-to-clip-space transform from scatterplot's live scales
  const xd = edgeXScale.domain();
  const yd = edgeYScale.domain();
  const xRange = xd[1] - xd[0] || 1;
  const yRange = yd[1] - yd[0] || 1;

  drawEdgesCmd({
    scale: [2 / xRange, 2 / yRange],
    offset: [-(xd[1] + xd[0]) / xRange, -(yd[1] + yd[0]) / yRange],
    color: edgeColor,
  });
  edgeNeedsRedraw = false;
}

const redrawEdges = renderEdges;

if (hasEdges) {
  scatterplot.subscribe('drawing', (event) => {
    if (!edgesVisible || !edgesLoaded) return;
    if (edgeNeedsRedraw || (event && event.isViewChanged)) renderEdges();
  });

  window.addEventListener('resize', () => {
    resizeEdgeCanvas();
    renderEdges();
  });

  edgeToggle.addEventListener('change', async (e) => {
    edgesVisible = e.target.checked;
    if (edgesVisible && !edgesLoaded) {
      edgeToggle.disabled = true;
      try {
        await loadEdges();
      } catch (err) {
        console.error('Failed to load edges:', err);
        edgesVisible = false;
        edgeToggle.checked = false;
        edgeToggle.disabled = false;
        return;
      }
      edgeToggle.disabled = false;
    }
    if (edgesVisible) {
      edgeNeedsRedraw = true;
      renderEdges();
    } else if (edgeRegl) {
      edgeRegl.poll();
      edgeRegl.clear({ color: [0, 0, 0, 0] });
    }
  });

  // For small datasets (<=1M), load edges eagerly during startup
  if (edgesVisible) await loadEdges();
} else {
  edgeToggle.parentElement.style.display = 'none';
}

// Color mapping
function buildContinuousMapping(rawValues, baseCmap) {
  const nums = new Float64Array(rawValues.length);
  const missing = new Array(rawValues.length);
  let min = Infinity, max = -Infinity, hasNaN = false;

  for (let i = 0; i < rawValues.length; i++) {
    const raw = rawValues[i];
    const v = Number(raw);
    nums[i] = v;
    const isMissing = raw === null || raw === undefined || !Number.isFinite(v);
    missing[i] = isMissing;
    if (isMissing) { hasNaN = true; continue; }
    if (v < min) min = v;
    if (v > max) max = v;
  }

  if (min === Infinity) { min = 0; max = 0; }
  const range = max === min ? 1 : max - min;
  const w = new Float32Array(rawValues.length);

  if (!hasNaN) {
    for (let i = 0; i < rawValues.length; i++) w[i] = (nums[i] - min) / range;
    return { cmap: baseCmap, w, min, max, hasNaN: false };
  }

  const baseCount = Math.max(1, baseCmap.length);
  const offset = 1 / baseCount;
  const scale = baseCount > 1 ? (baseCount - 1) / baseCount : 0;
  for (let i = 0; i < rawValues.length; i++) {
    w[i] = missing[i] ? 0 : ((nums[i] - min) / range) * scale + offset;
  }
  return { cmap: [NAN_FALLBACK_COLOR, ...baseCmap], w, min, max, hasNaN: true };
}

async function applyColor(columnName) {
  const col = await fetchColumn(columnName);
  if (!col) {
    scatterplot.set({ colorBy: null, pointColor: fallbackPointColor });
    edgeNeedsRedraw = true;
    scatterplot.draw({ x, y }).then(() => { redrawEdges(); });
    updateLegend('', null);
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];

  if (col.dtype === 'categorical') {
    const mapping = new Map();
    const z = new Float32Array(n);
    const values = col.values;
    for (let i = 0; i < n; i++) {
      const v = values[i];
      if (!mapping.has(v)) mapping.set(v, mapping.size);
      z[i] = mapping.get(v);
    }
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueA', pointColor: cmap });
    scatterplot.draw({ x, y, z, w: zeroArray }).then(() => { redrawEdges(); });
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueB', pointColor: mapping.cmap });
    scatterplot.draw({ x, y, z: zeroArray, w: mapping.w }).then(() => { redrawEdges(); });
  }
  updateLegend(columnName, col);
}

function formatValue(val) {
  if (typeof val === 'number') {
    const abs = Math.abs(val);
    if (abs >= 1000 || (abs > 0 && abs < 0.01)) return val.toExponential(2);
    return val.toFixed(3);
  }
  return String(val);
}

function buildGradient(colors) {
  if (!colors || colors.length === 0) return '#000000';
  const steps = Math.min(12, colors.length);
  if (steps === 1) return colors[0];
  const stops = [];
  for (let i = 0; i < steps; i++) {
    const t = i / (steps - 1);
    const idx = Math.round((colors.length - 1) * t);
    stops.push(colors[idx] + ' ' + Math.round(t * 100) + '%');
  }
  return 'linear-gradient(90deg, ' + stops.join(', ') + ')';
}

function updateLegend(columnName, col) {
  if (!col || col.role === 'label') {
    legend.classList.add('hidden');
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];
  legendTitle.textContent = columnName;

  if (col.dtype === 'categorical') {
    const mapping = new Map();
    const items = [];
    for (let i = 0; i < col.values.length; i++) {
      const v = col.values[i];
      if (!mapping.has(v)) { mapping.set(v, mapping.size); items.push(v); }
    }
    let html = '';
    for (let i = 0; i < items.length; i++) {
      html += '<div class="legend-item"><span class="legend-swatch" style="background:' +
        cmap[i % cmap.length] + '"></span><span>' + items[i] + '</span></div>';
    }
    legendContent.innerHTML = html;
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    let legendHtml =
      '<div class="legend-gradient" style="background:' + buildGradient(cmap) + '"></div>' +
      '<div class="legend-range"><span>' + formatValue(mapping.min) + '</span><span>' +
      formatValue(mapping.max) + '</span></div>';
    if (mapping.hasNaN) {
      legendHtml +=
        '<div class="legend-item"><span class="legend-swatch" style="background:' +
        NAN_FALLBACK_COLOR + '"></span><span>NaN</span></div>';
    }
    legendContent.innerHTML = legendHtml;
  }
  legend.classList.remove('hidden');
}

// Tooltip
let mouseX = 0, mouseY = 0;
canvas.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

function showTooltip(idx) {
