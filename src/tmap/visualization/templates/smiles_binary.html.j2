{#
  Binary SMILES Template - Extends binary template to add SmilesDrawer rendering

  Usage:
    viz.add_smiles("SMILES", smiles_list)
    viz.render_binary(template_name="smiles_binary.html.j2")
    or let TmapViz auto-pick when a SMILES column exists.
#}
{% extends "binary.html.j2" %}

{% block extra_styles %}
    #tooltip .structure-container {
      width: 240px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #tooltip .structure-container.hidden {
      display: none;
    }
    #tooltip #structure-svg {
      width: 240px;
      height: 200px;
    }
{% endblock %}

{% block extra_elements %}
  <script src="https://unpkg.com/smiles-drawer@2.1.7/dist/smiles-drawer.min.js"></script>
{% endblock %}

{% block extra_runtime %}
// SMILES rendering extension (binary mode)
const smilesColumn = metadata.smilesColumn;

if (smilesColumn && columns[smilesColumn]) {
  // Create structure container in tooltip
  const structureContainer = document.createElement('div');
  structureContainer.className = 'structure-container hidden';
  structureContainer.id = 'structure-container';
  tooltip.appendChild(structureContainer);

  const structureSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  structureSvg.id = 'structure-svg';
  structureContainer.appendChild(structureSvg);

  const g = typeof window !== 'undefined' ? window : globalThis;
  const SmiDrawerCtor = g.SmiDrawer;
  const SmilesDrawerLib = g.SmilesDrawer;

  const drawerOptions = { width: 240, height: 200, bondThickness: 1.0, compactDrawing: false };

  let drawer = null;
  let drawSmiles = null;

  if (SmiDrawerCtor) {
    drawer = new SmiDrawerCtor(drawerOptions);
    drawSmiles = (smiles) => drawer.draw(smiles, '#structure-svg', 'light');
  } else if (SmilesDrawerLib && SmilesDrawerLib.Drawer && SmilesDrawerLib.parse) {
    drawer = new SmilesDrawerLib.Drawer(drawerOptions);
    drawSmiles = (smiles) =>
      SmilesDrawerLib.parse(
        smiles,
        (tree) => drawer.draw(tree, 'structure-svg', 'light', false),
        (err) => {
          console.warn('Failed to parse SMILES:', smiles, err);
          structureContainer.classList.add('hidden');
        },
      );
  }

  if (!drawSmiles) {
    console.error('SmilesDrawer not loaded! Tried SmiDrawer and SmilesDrawer');
  } else {
    const originalShowTooltip = showTooltip;
    showTooltip = function(idx) {
      originalShowTooltip(idx);

      const smilesCol = columns[smilesColumn];
      if (!smilesCol) {
        structureContainer.classList.add('hidden');
        return;
      }

      const smiles = smilesCol.values[idx];
      if (!smiles || typeof smiles !== 'string' || !smiles.trim()) {
        structureContainer.classList.add('hidden');
        return;
      }

      structureContainer.classList.remove('hidden');
      structureSvg.innerHTML = '';

      try {
        drawSmiles(smiles);
      } catch (err) {
        console.warn('Failed to render SMILES:', smiles, err);
        structureContainer.classList.add('hidden');
      }
    };

    const originalHideTooltip = hideTooltip;
    hideTooltip = function() {
      originalHideTooltip();
      structureContainer.classList.add('hidden');
    };

    console.log('SMILES rendering enabled for column:', smilesColumn);
  }
} else {
  console.log('SMILES binary template loaded but no SMILES column specified');
}
{% endblock %}
