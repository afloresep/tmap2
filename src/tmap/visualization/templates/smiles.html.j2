{#
  SMILES Template - Extends base template to add molecular structure rendering

  This template adds:
  - SmilesDrawer integration for rendering SMILES strings
  - Molecular structure preview in tooltips

  Usage:
    viz.add_smiles("SMILES", smiles_list)
    viz.render(template_name="smiles.html.j2")
#}
{% extends "base.html.j2" %}

{% block extra_styles %}
    #tooltip .structure-container {
      width: 240px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #tooltip .structure-container.hidden {
      display: none;
    }
    #tooltip #structure-svg {
      width: 240px;
      height: 200px;
    }
    /* Card structure preview */
    .card .card-structure-container {
      display: flex;
      width: 216px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-bottom: 8px;
      align-items: center;
      justify-content: center;
    }
    .card .card-structure-container.hidden {
      display: none;
    }
    .card #card-structure-svg {
      width: 216px;
      height: 200px;
    }
{% endblock %}

{% block extra_elements %}
  <script src="https://unpkg.com/smiles-drawer@2.1.7/dist/smiles-drawer.min.js"></script>
{% endblock %}

{% block extra_runtime %}
// SMILES rendering extension
const smilesColumn = payload.smilesColumn;

if (smilesColumn && columns[smilesColumn]) {
  // Create structure container in tooltip
  const structureContainer = document.createElement('div');
  structureContainer.className = 'structure-container hidden';
  structureContainer.id = 'structure-container';
  tooltip.appendChild(structureContainer);

  // Create SVG element for SmilesDrawer
  const structureSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  structureSvg.id = 'structure-svg';
  structureContainer.appendChild(structureSvg);

  // Support both SmiDrawer (wrapper) and SmilesDrawer (core) globals
  const g = typeof window !== 'undefined' ? window : globalThis;
  const SmiDrawerCtor = g.SmiDrawer;
  const SmilesDrawerLib = g.SmilesDrawer;

  let drawer = null;
  let drawSmiles = null;

  const drawerOptions = {
    width: 240,
    height: 200,
    bondThickness: 1.0,
    compactDrawing: false,
  };

  if (SmiDrawerCtor) {
    drawer = new SmiDrawerCtor(drawerOptions);
    drawSmiles = (smiles) => drawer.draw(smiles, '#structure-svg', 'light');
  } else if (SmilesDrawerLib && SmilesDrawerLib.Drawer && SmilesDrawerLib.parse) {
    drawer = new SmilesDrawerLib.Drawer(drawerOptions);
    drawSmiles = (smiles) => SmilesDrawerLib.parse(
      smiles,
      (tree) => drawer.draw(tree, 'structure-svg', 'light', false),
      (err) => {
        console.warn('Failed to parse SMILES:', smiles, err);
        structureContainer.classList.add('hidden');
      },
    );
  }

  if (!drawSmiles) {
    console.error('SmilesDrawer not loaded! Tried window.SmiDrawer and window.SmilesDrawer');
  } else {
    // Override showTooltip to add molecule rendering
    const originalShowTooltip = showTooltip;
    showTooltip = function(idx) {
      originalShowTooltip(idx);

      const smilesCol = columns[smilesColumn];
      if (!smilesCol) {
        structureContainer.classList.add('hidden');
        return;
      }

      const smiles = smilesCol.values[idx];
      if (!smiles || typeof smiles !== 'string' || smiles.trim() === '') {
        structureContainer.classList.add('hidden');
        return;
      }

      structureContainer.classList.remove('hidden');

      // Clear previous drawing
      structureSvg.innerHTML = '';

      try {
        drawSmiles(smiles);
      } catch (e) {
        console.warn('Failed to render SMILES:', smiles, e);
        structureContainer.classList.add('hidden');
      }
    };

    // Override hideTooltip to clean up
    const originalHideTooltip = hideTooltip;
    hideTooltip = function() {
      originalHideTooltip();
      structureContainer.classList.add('hidden');
    };

    console.log('SMILES rendering enabled for column:', smilesColumn);

    // Card structure rendering
    cardStack.addEventListener('cardrendered', (e) => {
      const { idx, smilesValue } = e.detail;
      const cardStructure = document.getElementById('card-structure');
      if (!cardStructure) return;

      if (!smilesValue || typeof smilesValue !== 'string' || !smilesValue.trim()) {
        cardStructure.classList.add('hidden');
        return;
      }

      // Create SVG if not exists
      let cardSvg = document.getElementById('card-structure-svg');
      if (!cardSvg) {
        cardSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        cardSvg.id = 'card-structure-svg';
        cardStructure.appendChild(cardSvg);
      }

      cardStructure.classList.remove('hidden');
      cardSvg.innerHTML = '';

      // Create a separate drawer for cards with matching dimensions
      const cardDrawerOptions = { width: 216, height: 200, bondThickness: 1.0, compactDrawing: false };

      try {
        if (SmiDrawerCtor) {
          const cardDrawer = new SmiDrawerCtor(cardDrawerOptions);
          cardDrawer.draw(smilesValue, '#card-structure-svg', 'light');
        } else if (SmilesDrawerLib && SmilesDrawerLib.Drawer && SmilesDrawerLib.parse) {
          const cardDrawer = new SmilesDrawerLib.Drawer(cardDrawerOptions);
          SmilesDrawerLib.parse(
            smilesValue,
            (tree) => cardDrawer.draw(tree, 'card-structure-svg', 'light', false),
            (err) => {
              console.warn('Failed to parse SMILES for card:', smilesValue, err);
              cardStructure.classList.add('hidden');
            },
          );
        }
      } catch (err) {
        console.warn('Failed to render SMILES in card:', smilesValue, err);
        cardStructure.classList.add('hidden');
      }
    });
  }
} else {
  console.log('SMILES template loaded but no SMILES column specified');
}
{% endblock %}
