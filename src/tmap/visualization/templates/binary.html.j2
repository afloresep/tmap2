{#
  Binary Template - Optimized for large datasets (5M+ points)

  Uses:
  - Uint16 quantized coordinates (4x smaller than JSON)
  - Gzip-compressed typed arrays
  - WebWorker decoding (non-blocking)
  - Transferable buffers (zero-copy)

  Usage:
    viz.render(template_name="binary.html.j2")
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: {{ background_color }};
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    #canvas {
      width: 100vw;
      height: 100vh;
      display: block;
    }
    #title {
      position: fixed;
      top: 12px;
      left: 12px;
      padding: 6px 10px;
      border-radius: 6px;
      background: rgba(0, 0, 0, 0.4);
      font-size: 14px;
      letter-spacing: 0.4px;
      z-index: 120;
    }
    #controls {
      position: fixed;
      top: 12px;
      right: 12px;
      padding: 8px 10px;
      background: #000;
      border-radius: 6px;
      font-size: 13px;
      color: #fff;
      min-width: 160px;
      z-index: 120;
    }
    #controls label {
      font-size: 12px;
      color: #fff;
      display: block;
      margin-bottom: 4px;
    }
    #controls select {
      width: 100%;
      padding: 6px 8px;
      border-radius: 4px;
      border: 1px solid #fff;
      background: #000;
      color: #fff;
    }
    #legend {
      position: fixed;
      bottom: 12px;
      right: 12px;
      padding: 10px 12px;
      background: #000;
      border: 1px solid #333;
      border-radius: 6px;
      font-size: 12px;
      color: #fff;
      min-width: 160px;
      max-width: 240px;
      max-height: 240px;
      overflow: auto;
      z-index: 120;
    }
    #legend.hidden { display: none; }
    #legend-title {
      font-weight: 600;
      margin-bottom: 6px;
    }
    .legend-gradient {
      height: 10px;
      border-radius: 4px;
      border: 1px solid #fff;
    }
    .legend-range {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      margin-top: 4px;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 2px 0;
    }
    .legend-swatch {
      width: 12px;
      height: 12px;
      border-radius: 3px;
      border: 1px solid #fff;
    }
    #tooltip {
      position: fixed;
      pointer-events: none;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid #333;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 12px;
      color: #e0e0e0;
      width: 240px;
      display: none;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      z-index: 130;
    }
    #tooltip.visible { display: block; }
    #tooltip .label { font-weight: 700; margin-bottom: 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #tooltip .row { display: flex; justify-content: space-between; gap: 12px; margin: 2px 0; }
    #tooltip .key { color: #9ca3af; flex-shrink: 0; }
    #tooltip .value { color: #e5e7eb; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }

    /* Card stack - pinned cards from single clicks */
    #card-stack {
      position: fixed;
      bottom: 12px;
      left: 12px;
      z-index: 100;
    }
    #card-stack.hidden { display: none; }
    .card {
      width: 240px;
      background: rgba(0, 0, 0, 0.9);
      border: 1px solid #444;
      border-radius: 8px;
      padding: 12px;
      color: #e0e0e0;
      font-size: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
      padding-bottom: 8px;
      border-bottom: 1px solid #333;
    }
    .card-nav {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #9ca3af;
    }
    .card-nav button {
      background: #333;
      border: 1px solid #555;
      color: #fff;
      width: 22px;
      height: 22px;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      padding: 0;
    }
    .card-nav button:hover { background: #444; }
    .card-nav button:disabled { opacity: 0.3; cursor: not-allowed; }
    .card-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 18px;
      cursor: pointer;
      padding: 0 0 0 8px;
      line-height: 1;
    }
    .card-close:hover { color: #fff; }
    .card-minimize {
      background: transparent;
      border: none;
      color: #666;
      font-size: 14px;
      cursor: pointer;
      padding: 0 4px;
      line-height: 1;
    }
    .card-minimize:hover { color: #fff; }
    .card.minimized .card-body { display: none; }
    .card.minimized { padding: 8px 12px; }
    .card.minimized .card-header { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .card-body { }
    .card-label {
      font-weight: 700;
      margin-bottom: 8px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
    }
    .card-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      text-align: right;
    }
    .card-copy-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
      background: #1a1a1a;
      padding: 6px 8px;
      border-radius: 4px;
    }
    .card-copy-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-copy-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      font-family: monospace;
      font-size: 11px;
    }
    .card-copy-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 3px 8px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 10px;
      flex-shrink: 0;
      font-weight: 500;
    }
    .card-copy-btn:hover { background: #3a8eef; }
    .card-copy-btn.copied { background: #22c55e; }
    .card-structure-container { display: none; }

    /* Search panel - top left below title */
    #search-panel {
      position: fixed;
      top: 52px;
      left: 12px;
      padding: 8px 10px;
      background: #000;
      border-radius: 6px;
      font-size: 12px;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 200px;
      z-index: 90;
    }
    #search-panel label { font-size: 11px; color: #9ca3af; }
    #search-panel select, #search-panel input[type="text"] {
      width: 100%;
      padding: 5px 8px;
      border-radius: 4px;
      border: 1px solid #555;
      background: #1a1a1a;
      color: #fff;
      font-size: 12px;
      box-sizing: border-box;
    }
    #search-panel .search-row {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    #search-panel .search-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 5px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      white-space: nowrap;
    }
    #search-panel .search-btn:hover { background: #3a8eef; }
    #search-panel .search-btn.clear { background: #333; border: 1px solid #555; }
    #search-panel .search-btn.clear:hover { background: #444; }
    #search-panel .partial-match {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      cursor: pointer;
    }
    #search-results {
      font-size: 11px;
      color: #9ca3af;
      min-height: 16px;
    }

    /* Export panel - for multi-select */
    #export-panel {
      position: fixed;
      bottom: 12px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0, 0, 0, 0.9);
      border: 1px solid #444;
      border-radius: 8px;
      padding: 12px 16px;
      color: #e0e0e0;
      font-size: 12px;
      z-index: 100;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
      min-width: 280px;
    }
    #export-panel.hidden { display: none; }
    .export-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .export-title { font-weight: 600; font-size: 13px; }
    .export-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 16px;
      cursor: pointer;
      padding: 0;
    }
    .export-close:hover { color: #fff; }
    .export-columns {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 12px;
      margin-bottom: 12px;
      padding: 8px;
      background: #1a1a1a;
      border-radius: 4px;
      max-width: 400px;
    }
    .export-columns label {
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      font-size: 11px;
    }
    .export-columns input[type="checkbox"] { cursor: pointer; }
    .export-actions {
      display: flex;
      gap: 8px;
    }
    .export-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 6px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }
    .export-btn:hover { background: #3a8eef; }
    .export-btn.secondary {
      background: #333;
      border: 1px solid #555;
    }
    .export-btn.secondary:hover { background: #444; }

    /* Loading overlay */
    #loading {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: {{ background_color }};
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    #loading.hidden { display: none; }
    #loading-text {
      font-size: 18px;
      margin-bottom: 20px;
    }
    #progress-bar {
      width: 300px;
      height: 8px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 4px;
      overflow: hidden;
    }
    #progress-fill {
      height: 100%;
      background: #4a9eff;
      width: 0%;
      transition: width 0.2s;
    }
    #progress-text {
      margin-top: 10px;
      font-size: 14px;
      color: #9ca3af;
    }
{% block extra_styles %}{% endblock %}
  </style>
</head>
<body>
  <div id="loading">
    <div id="loading-text">Loading visualization...</div>
    <div id="progress-bar"><div id="progress-fill"></div></div>
    <div id="progress-text">Initializing...</div>
  </div>

  <div id="title">{{ title }}</div>
  <div id="controls">
    <label for="color-select">Color By Layout</label>
    <select id="color-select"></select>
    <label style="margin-top:6px;cursor:pointer;"><input type="checkbox" id="edge-toggle" checked style="cursor:pointer;"> Show edges</label>
  </div>
  <canvas id="canvas"></canvas>
  <div id="tooltip">
    <div class="label" id="tooltip-label"></div>
    <div id="tooltip-content"></div>
  </div>
  <div id="legend" class="hidden">
    <div id="legend-title"></div>
    <div id="legend-content"></div>
  </div>
  <div id="card-stack" class="hidden"></div>
  <div id="export-panel" class="hidden">
    <div class="export-header">
      <span class="export-title" id="export-title">0 points selected</span>
      <button class="export-close" id="export-close">&times;</button>
    </div>
    <div class="export-columns" id="export-columns"></div>
    <div class="export-actions">
      <button class="export-btn" id="export-csv">Export CSV</button>
      <button class="export-btn secondary" id="export-tsv">Export TSV</button>
      <button class="export-btn secondary" id="export-clear">Clear</button>
    </div>
  </div>
  <div id="search-panel">
    <label for="search-column">Search in column</label>
    <select id="search-column"></select>
    <label for="search-input">Search query</label>
    <div class="search-row">
      <input type="text" id="search-input" placeholder="Enter search term...">
      <button class="search-btn" id="search-btn">Search</button>
    </div>
    <div class="search-row">
      <label class="partial-match">
        <input type="checkbox" id="partial-match"> Partial match
      </label>
      <button class="search-btn clear" id="clear-search">Clear</button>
    </div>
    <div id="search-results"></div>
  </div>

{% block extra_elements %}{% endblock %}

  <!-- Binary data sections -->
  <script id="tmap-header" type="application/json">{{ header_json }}</script>
  <script id="tmap-coords" type="application/octet-stream">{{ coords_b64 }}</script>
{% for name, data in columns_b64.items() %}
  <script id="tmap-col-{{ name }}" type="application/octet-stream">{{ data }}</script>
{% endfor %}
{% if edges_b64 %}
  <script id="tmap-edges" type="application/octet-stream">{{ edges_b64 }}</script>
{% endif %}

  <!-- fflate for decompression (UMD build) -->
  <script src="https://cdn.jsdelivr.net/npm/fflate@0.8.2/umd/index.min.js"></script>

  <!-- Scatterplot libraries -->
  <script type="module">
    const decode = (b64) => atob(b64);
    const mkModule = (code) =>
      URL.createObjectURL(new Blob([code], { type: 'application/javascript' }));

    const reglSource = decode("{{ runtime_regl }}");
    const pubSubSource = decode("{{ runtime_pubsub }}");
    const scatterSourceRaw = decode("{{ runtime_scatterplot }}");

    const reglModuleSource = `
const module = { exports: {} };
const exports = module.exports;
const globalThisRef = typeof globalThis !== 'undefined' ? globalThis : window;
${reglSource}
export default module.exports || globalThisRef.createREGL || createREGL;
`;
    const reglUrl = mkModule(reglModuleSource);
    const pubSubUrl = mkModule(pubSubSource);
    const scatterSource = scatterSourceRaw
      .replace(/from "regl"/g, 'from "' + reglUrl + '"')
      .replace(/from 'regl'/g, 'from "' + reglUrl + '"')
      .replace(/from "pub-sub-es"/g, 'from "' + pubSubUrl + '"')
      .replace(/from 'pub-sub-es'/g, 'from "' + pubSubUrl + '"');
    const scatterUrl = mkModule(scatterSource);

    const runtime = `
import createScatterplot from '${scatterUrl}';

// ============================================
// Binary Data Decoding
// ============================================

const loading = document.getElementById('loading');
const progressFill = document.getElementById('progress-fill');
const progressText = document.getElementById('progress-text');

function updateProgress(percent, text) {
  progressFill.style.width = percent + '%';
  progressText.textContent = text;
}

// Decode gzip-compressed base64 using fflate
function decodeGzipBase64(base64, dtype) {
  const binaryString = atob(base64);
  const bytes = new Uint8Array(binaryString.length);
  for (let i = 0; i < binaryString.length; i++) {
    bytes[i] = binaryString.charCodeAt(i);
  }

  const decompressed = fflate.gunzipSync(bytes);

  switch (dtype) {
    case 'uint16': return new Uint16Array(decompressed.buffer);
    case 'uint32': return new Uint32Array(decompressed.buffer);
    case 'float32': return new Float32Array(decompressed.buffer);
    case 'int32': return new Int32Array(decompressed.buffer);
    default: throw new Error('Unknown dtype: ' + dtype);
  }
}

// Dequantize coords
function dequantizeCoords(quantized, bits = 16) {
  const n = quantized.length / 2;
  const maxVal = bits === 16 ? 65535 : 4294967295;
  const scale = 2.0 / maxVal;

  const x = new Float32Array(n);
  const y = new Float32Array(n);

  for (let i = 0; i < n; i++) {
    x[i] = quantized[i * 2] * scale - 1.0;
    y[i] = quantized[i * 2 + 1] * scale - 1.0;
  }

  return { x, y };
}

// ============================================
// Load Data
// ============================================

updateProgress(5, 'Parsing header...');

const header = JSON.parse(document.getElementById('tmap-header').textContent);
const coordsB64 = document.getElementById('tmap-coords').textContent;

const metadata = header.metadata || {};
const colormaps = metadata.colormaps || {};
const layoutOptions = metadata.layoutOptions || [];
const labelOptions = metadata.labelOptions || [];
const columnMeta = header.columns || {};

updateProgress(10, 'Decoding coordinates...');

// Decode coordinates
const coordDtype = header.coordDtype || 'uint16';
const coordBits = coordDtype === 'uint16' ? 16 : 32;
const quantizedCoords = decodeGzipBase64(coordsB64, coordDtype);
const { x, y } = dequantizeCoords(quantizedCoords, coordBits);
const n = x.length;

// Decode edges
const edgesEl = document.getElementById('tmap-edges');
let edgesS = [], edgesT = [];
const nEdges = (metadata.nEdges || 0);
if (edgesEl && nEdges > 0) {
  const edgesRaw = decodeGzipBase64(edgesEl.textContent, 'uint32');
  edgesS = edgesRaw.subarray(0, nEdges);
  edgesT = edgesRaw.subarray(nEdges, 2 * nEdges);
}
const hasEdges = edgesS.length > 0 && metadata.showEdges !== false;
const parsedEdgeWidth = Number(metadata.edgeWidth);
const edgeWidth = Number.isFinite(parsedEdgeWidth) && parsedEdgeWidth > 0 ? parsedEdgeWidth : 2;
const edgeStrokeStyle = metadata.edgeStrokeStyle || 'rgba(0, 0, 0, 0.5)';
const edgeLineCap = ['butt', 'round', 'square'].includes(metadata.edgeLineCap)
  ? metadata.edgeLineCap
  : 'round';
const E = edgesS.length;
const N = n;

updateProgress(40, 'Decoding columns...');

// Decode columns
const columns = {};
const columnNames = Object.keys(columnMeta);
let colIdx = 0;

for (const name of columnNames) {
  const meta = columnMeta[name];
  const el = document.getElementById('tmap-col-' + name);

  // String columns (labels / SMILES) are embedded in metadata, not separate script tags
  if (!el) {
    if (meta && meta.dtype === 'string' && Array.isArray(meta.values)) {
      columns[name] = {
        values: meta.values,
        dtype: 'string',
        role: meta.role,
        colormap: meta.colormap,
      };
      colIdx++;
      const pct = 40 + (colIdx / columnNames.length) * 40;
      updateProgress(pct, 'Decoding ' + name + '...');
    }
    continue;
  }

  const b64 = el.textContent;
  const decoded = decodeGzipBase64(b64, meta.dtype);

  if (meta.dictionary) {
    // Categorical: map indices to values
    columns[name] = {
      values: Array.from(decoded).map(i => meta.dictionary[i]),
      dtype: 'categorical',
      role: meta.role,
      colormap: meta.colormap,
    };
  } else {
    columns[name] = {
      values: decoded,
      dtype: meta.dtype === 'float32' ? 'continuous' : meta.dtype,
      role: meta.role,
      colormap: meta.colormap,
    };
  }

  colIdx++;
  const pct = 40 + (colIdx / columnNames.length) * 40;
  updateProgress(pct, 'Decoding ' + name + '...');
}

updateProgress(85, 'Initializing visualization...');

// ============================================
// Visualization Setup
// ============================================

const canvas = document.getElementById('canvas');
const colorSelect = document.getElementById('color-select');
const tooltip = document.getElementById('tooltip');
const tooltipLabel = document.getElementById('tooltip-label');
const tooltipContent = document.getElementById('tooltip-content');
const legend = document.getElementById('legend');
const legendTitle = document.getElementById('legend-title');
const legendContent = document.getElementById('legend-content');

function createLinearScale(initialDomain, initialRange) {
  let d0 = initialDomain[0];
  let d1 = initialDomain[1];
  let r0 = initialRange[0];
  let r1 = initialRange[1];
  const scale = (value) => {
    const denom = d1 - d0;
    if (denom === 0) return r0;
    return r0 + ((value - d0) / denom) * (r1 - r0);
  };
  scale.domain = (nextDomain) => {
    if (nextDomain === undefined) return [d0, d1];
    d0 = nextDomain[0];
    d1 = nextDomain[1];
    return scale;
  };
  scale.range = (nextRange) => {
    if (nextRange === undefined) return [r0, r1];
    r0 = nextRange[0];
    r1 = nextRange[1];
    return scale;
  };
  return scale;
}

const edgeXScale = createLinearScale([-1, 1], [0, canvas.clientWidth || window.innerWidth]);
const edgeYScale = createLinearScale([-1, 1], [canvas.clientHeight || window.innerHeight, 0]);

const initialColor = layoutOptions[0] || '';
const fallbackPointColor = metadata.pointColor || '#4a9eff';

const scatterplot = createScatterplot({
  canvas,
  width: canvas.clientWidth || window.innerWidth,
  height: canvas.clientHeight || window.innerHeight,
  pointSize: metadata.pointSize || 4,
  pointSizeSelected: 8,  // 2x size when selected
  opacity: metadata.opacity ?? 0.85,
  opacityInactiveScale: 0.5,  // Dim non-selected points when selection active
  backgroundColor: metadata.backgroundColor || [0, 0, 0, 1],
  pointColor: fallbackPointColor,
  pointOutlineWidth: 2,
  colorBy: null,
  lassoInitiator: false,
  xScale: edgeXScale,
  yScale: edgeYScale,
  performanceMode: N > 500000,
});

const zeroArray = new Float32Array(n);

// === Edge Canvas Overlay ===
let redrawEdges = function() {};
let edgeNeedsRedraw = hasEdges;
let edgesVisible = true;

const edgeToggle = document.getElementById('edge-toggle');

if (hasEdges) {
  canvas.style.position = 'fixed';
  canvas.style.top = '0';
  canvas.style.left = '0';
  canvas.style.zIndex = '2';

  const edgeCanvas = document.createElement('canvas');
  edgeCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:1;';
  canvas.parentNode.insertBefore(edgeCanvas, canvas);
  let edgeCtx = edgeCanvas.getContext('2d');

  function resizeEdgeCanvas() {
    const dpr = window.devicePixelRatio || 1;
    edgeCanvas.width = window.innerWidth * dpr;
    edgeCanvas.height = window.innerHeight * dpr;
    edgeCtx = edgeCanvas.getContext('2d');
    edgeCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resizeEdgeCanvas();

  redrawEdges = function() {
    const w = window.innerWidth;
    const h = window.innerHeight;
    edgeCtx.clearRect(0, 0, w, h);

    if (!edgesVisible) {
      edgeNeedsRedraw = false;
      return;
    }

    const canvasRect = canvas.getBoundingClientRect();
    const left = canvasRect.left;
    const top = canvasRect.top;
    const margin = 50;
    const minX = 0 - margin;
    const maxX = w + margin;
    const minY = 0 - margin;
    const maxY = h + margin;

    edgeCtx.beginPath();
    edgeCtx.strokeStyle = edgeStrokeStyle;
    edgeCtx.lineWidth = edgeWidth;
    edgeCtx.lineCap = edgeLineCap;
    edgeCtx.lineJoin = 'round';

    for (let i = 0; i < E; i++) {
      const sx = left + edgeXScale(x[edgesS[i]]);
      const sy = top + edgeYScale(y[edgesS[i]]);
      const tx = left + edgeXScale(x[edgesT[i]]);
      const ty = top + edgeYScale(y[edgesT[i]]);
      // Skip edges entirely outside viewport
      if ((sx < minX && tx < minX) || (sx > maxX && tx > maxX) ||
          (sy < minY && ty < minY) || (sy > maxY && ty > maxY)) continue;
      edgeCtx.moveTo(sx, sy);
      edgeCtx.lineTo(tx, ty);
    }

    edgeCtx.stroke();
    edgeNeedsRedraw = false;
  };

  scatterplot.subscribe('drawing', (event) => {
    if (!edgeNeedsRedraw && !(event && event.isViewChanged)) {
      return;
    }
    redrawEdges();
  });

  window.addEventListener('resize', () => {
    resizeEdgeCanvas();
    edgeNeedsRedraw = true;
    redrawEdges();
  });

  edgeToggle.addEventListener('change', (e) => {
    edgesVisible = e.target.checked;
    edgeNeedsRedraw = true;
    redrawEdges();
  });
} else {
  // Hide edge toggle when no edges
  edgeToggle.parentElement.style.display = 'none';
}
const NAN_FALLBACK_COLOR = '#000000';

function buildContinuousMapping(rawValues, baseCmap) {
  const nums = new Float64Array(rawValues.length);
  const missing = new Array(rawValues.length);
  let min = Infinity;
  let max = -Infinity;
  let hasNaN = false;

  for (let i = 0; i < rawValues.length; i++) {
    const raw = rawValues[i];
    const v = Number(raw);
    nums[i] = v;
    const isMissing = raw === null || raw === undefined || !Number.isFinite(v);
    missing[i] = isMissing;
    if (isMissing) {
      hasNaN = true;
      continue;
    }

    if (v < min) min = v;
    if (v > max) max = v;
  }

  if (min === Infinity) {
    min = 0;
    max = 0;
  }

  const range = max === min ? 1 : max - min;
  const w = new Float32Array(rawValues.length);

  if (!hasNaN) {
    for (let i = 0; i < rawValues.length; i++) {
      w[i] = (nums[i] - min) / range;
    }
    return {
      cmap: baseCmap,
      w,
      min,
      max,
      hasNaN: false,
    };
  }

  const baseCount = Math.max(1, baseCmap.length);
  const offset = 1 / baseCount;
  const scale = baseCount > 1 ? (baseCount - 1) / baseCount : 0;
  for (let i = 0; i < rawValues.length; i++) {
    w[i] = missing[i] ? 0 : ((nums[i] - min) / range) * scale + offset;
  }

  return {
    cmap: [NAN_FALLBACK_COLOR, ...baseCmap],
    w,
    min,
    max,
    hasNaN: true,
  };
}

function applyColor(columnName) {
  const col = columns[columnName];
  if (!col) {
    scatterplot.set({ colorBy: null, pointColor: fallbackPointColor });
    edgeNeedsRedraw = true;
    scatterplot.draw({ x, y }).then(() => {
      redrawEdges();
    });
    updateLegend('');
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];

  if (col.dtype === 'categorical') {
    const mapping = new Map();
    const z = new Float32Array(n);
    const values = col.values;
    for (let i = 0; i < n; i++) {
      const v = values[i];
      if (!mapping.has(v)) mapping.set(v, mapping.size);
      z[i] = mapping.get(v);
    }
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueA', pointColor: cmap });
    scatterplot.draw({ x, y, z, w: zeroArray }).then(() => {
      redrawEdges();
    });
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueB', pointColor: mapping.cmap });
    scatterplot.draw({ x, y, z: zeroArray, w: mapping.w }).then(() => {
      redrawEdges();
    });
  }
  updateLegend(columnName);
}

function formatValue(val) {
  if (typeof val === 'number') {
    const abs = Math.abs(val);
    if (abs >= 1000 || (abs > 0 && abs < 0.01)) return val.toExponential(2);
    return val.toFixed(3);
  }
  return String(val);
}

function buildGradient(colors) {
  if (!colors || colors.length === 0) return '#000000';
  const steps = Math.min(12, colors.length);
  if (steps === 1) return colors[0];
  const stops = [];
  for (let i = 0; i < steps; i++) {
    const t = i / (steps - 1);
    const idx = Math.round((colors.length - 1) * t);
    stops.push(colors[idx] + ' ' + Math.round(t * 100) + '%');
  }
  return 'linear-gradient(90deg, ' + stops.join(', ') + ')';
}

function updateLegend(columnName) {
  const col = columns[columnName];
  if (!col || col.role === 'label') {
    legend.classList.add('hidden');
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];
  legendTitle.textContent = columnName;

  if (col.dtype === 'categorical') {
    const mapping = new Map();
    const items = [];
    for (let i = 0; i < col.values.length; i++) {
      const v = col.values[i];
      if (!mapping.has(v)) {
        mapping.set(v, mapping.size);
        items.push(v);
      }
    }
    let html = '';
    for (let i = 0; i < items.length; i++) {
      html += '<div class="legend-item"><span class="legend-swatch" style="background:' +
        cmap[i % cmap.length] + '"></span><span>' + items[i] + '</span></div>';
    }
    legendContent.innerHTML = html;
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    let legendHtml =
      '<div class="legend-gradient" style="background:' + buildGradient(cmap) + '"></div>' +
      '<div class="legend-range"><span>' + formatValue(mapping.min) + '</span><span>' +
      formatValue(mapping.max) + '</span></div>';
    if (mapping.hasNaN) {
      legendHtml +=
        '<div class="legend-item"><span class="legend-swatch" style="background:' +
        NAN_FALLBACK_COLOR + '"></span><span>NaN</span></div>';
    }
    legendContent.innerHTML = legendHtml;
  }
  legend.classList.remove('hidden');
}

// Tooltip
let mouseX = 0, mouseY = 0;
canvas.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

function showTooltip(idx) {
  // Get label from first label column
  let label = 'Point ' + idx;
  for (const name of labelOptions) {
    const col = columns[name];
    if (col && col.values[idx] !== undefined) {
      label = col.values[idx];
      break;
    }
  }
  tooltipLabel.textContent = label;

  let html = '';
  for (const name of labelOptions) {
    const col = columns[name];
    if (!col) continue;
    const val = col.values[idx];
    html += '<div class="row"><span class="key">' + name + '</span><span class="value">' + formatValue(val) + '</span></div>';
  }
  tooltipContent.innerHTML = html;

  tooltip.classList.add('visible');
  const rect = tooltip.getBoundingClientRect();
  let left = mouseX + 12;
  let top = mouseY + 12;
  if (left + rect.width > window.innerWidth - 8) left = mouseX - rect.width - 12;
  if (top + rect.height > window.innerHeight - 8) top = mouseY - rect.height - 12;
  tooltip.style.left = left + 'px';
  tooltip.style.top = top + 'px';
}

function hideTooltip() {
  tooltip.classList.remove('visible');
}

scatterplot.subscribe('pointover', (idx) => showTooltip(idx));
scatterplot.subscribe('pointout', hideTooltip);

// Resize
window.addEventListener('resize', () => {
  const { width, height } = canvas.getBoundingClientRect();
  scatterplot.set({ width, height });
});

// Color selector
for (const name of layoutOptions) {
  const col = columns[name];
  if (!col) continue;
  const opt = document.createElement('option');
  opt.value = name;
  opt.textContent = name + ' (' + col.dtype + ')';
  colorSelect.appendChild(opt);
}
if (initialColor) colorSelect.value = initialColor;
colorSelect.addEventListener('change', (e) => applyColor(e.target.value));

// Initial render
updateProgress(95, 'Rendering...');
applyColor(initialColor || '');
redrawEdges();

// Hide loading
updateProgress(100, 'Complete!');
setTimeout(() => {
  loading.classList.add('hidden');
}, 200);

console.log('Loaded ' + n.toLocaleString() + ' points');

// ============================================
// Card Stack System (single-click pinned cards)
// ============================================

const cardStack = document.getElementById('card-stack');
const pinnedCards = []; // Array of point indices
let currentCardIndex = 0;

// >>> CARD_STACK_LIMIT: Change this value to adjust maximum pinned cards <<<
const MAX_CARDS = 50;

function getLabel(idx) {
  for (const name of labelOptions) {
    const col = columns[name];
    if (col && col.values[idx] !== undefined) {
      return col.values[idx];
    }
  }
  return 'Point ' + idx;
}

let hoveredPointIndex = -1;
let cardMinimized = false;
scatterplot.subscribe('pointover', (idx) => { hoveredPointIndex = idx; });
scatterplot.subscribe('pointout', () => { hoveredPointIndex = -1; });

// Drag detection - only select on click, not drag
let mouseDownPos = null;
const DRAG_THRESHOLD = 5; // pixels

canvas.addEventListener('mousedown', (e) => {
  mouseDownPos = { x: e.clientX, y: e.clientY };
});

canvas.addEventListener('mouseup', (e) => {
  if (!mouseDownPos) return;

  // Check if this was a drag (moved more than threshold)
  const dx = e.clientX - mouseDownPos.x;
  const dy = e.clientY - mouseDownPos.y;
  const distance = Math.sqrt(dx * dx + dy * dy);
  mouseDownPos = null;

  if (distance > DRAG_THRESHOLD) return; // Was a drag, not a click

  // Ignore if shift/ctrl held (multi-select mode)
  if (e.shiftKey || e.ctrlKey || e.metaKey) return;
  if (hoveredPointIndex < 0) return;

  const idx = hoveredPointIndex;
  const existingIndex = pinnedCards.indexOf(idx);

  if (existingIndex >= 0) {
    // Jump to existing card
    currentCardIndex = existingIndex;
  } else {
    // Add new card (remove oldest if at limit)
    if (pinnedCards.length >= MAX_CARDS) {
      pinnedCards.shift();
    }
    pinnedCards.push(idx);
    currentCardIndex = pinnedCards.length - 1;
  }
  renderCardStack();
});

function truncateString(str, maxLen) {
  if (!str || str.length <= maxLen) return str;
  return str.substring(0, maxLen - 3) + '...';
}

function renderCardStack() {
  if (pinnedCards.length === 0) {
    cardStack.classList.add('hidden');
    cardStack.innerHTML = '';
    return;
  }

  cardStack.classList.remove('hidden');
  const idx = pinnedCards[currentCardIndex];
  const label = getLabel(idx);

  // Find SMILES column (if any)
  const smilesColName = metadata.smilesColumn;
  const smilesCol = smilesColName ? columns[smilesColName] : null;
  const smilesValue = smilesCol ? smilesCol.values[idx] : null;

  let html = '<div class="card' + (cardMinimized ? ' minimized' : '') + '">';

  // Header with navigation
  html += '<div class="card-header">';
  html += '<div class="card-nav">';
  html += '<button id="card-prev" ' + (currentCardIndex <= 0 ? 'disabled' : '') + '>&larr;</button>';
  html += '<span>' + (currentCardIndex + 1) + ' of ' + pinnedCards.length + '</span>';
  html += '<button id="card-next" ' + (currentCardIndex >= pinnedCards.length - 1 ? 'disabled' : '') + '>&rarr;</button>';
  html += '</div>';
  html += '<div>';
  html += '<button class="card-minimize" id="card-minimize" title="' + (cardMinimized ? 'Expand' : 'Minimize') + '">' + (cardMinimized ? '&#9650;' : '&#9660;') + '</button>';
  html += '<button class="card-close" id="card-close" title="Close">&times;</button>';
  html += '</div>';
  html += '</div>';

  // Card body (hidden when minimized)
  html += '<div class="card-body">';

  // Label
  html += '<div class="card-label">' + truncateString(String(label), 40) + '</div>';

  // Structure container placeholder (extended by SMILES templates)
  html += '<div class="card-structure-container" id="card-structure"></div>';

  // SMILES row with copy button (if present)
  if (smilesValue && typeof smilesValue === 'string') {
    html += '<div class="card-copy-row">';
    html += '<span class="key">SMILES</span>';
    html += '<span class="value">' + truncateString(smilesValue, 25) + '</span>';
    html += '<button class="card-copy-btn" id="copy-smiles" data-value="' + smilesValue.replace(/"/g, '&quot;') + '">Copy</button>';
    html += '</div>';
  }

  // Other label fields
  for (const name of labelOptions) {
    if (name === smilesColName) continue; // Already shown above
    const col = columns[name];
    if (!col) continue;
    const val = col.values[idx];
    const displayVal = truncateString(formatValue(val), 30);

    // Add copy button for string values
    if (typeof val === 'string' && val.length > 0) {
      html += '<div class="card-copy-row">';
      html += '<span class="key">' + name + '</span>';
      html += '<span class="value">' + displayVal + '</span>';
      html += '<button class="card-copy-btn" data-value="' + String(val).replace(/"/g, '&quot;') + '">Copy</button>';
      html += '</div>';
    } else {
      html += '<div class="card-row">';
      html += '<span class="key">' + name + '</span>';
      html += '<span class="value">' + displayVal + '</span>';
      html += '</div>';
    }
  }

  html += '</div>'; // close card-body
  html += '</div>'; // close card
  cardStack.innerHTML = html;

  // Attach event listeners
  document.getElementById('card-prev')?.addEventListener('click', () => {
    if (currentCardIndex > 0) { currentCardIndex--; renderCardStack(); }
  });
  document.getElementById('card-next')?.addEventListener('click', () => {
    if (currentCardIndex < pinnedCards.length - 1) { currentCardIndex++; renderCardStack(); }
  });
  document.getElementById('card-minimize')?.addEventListener('click', () => {
    cardMinimized = !cardMinimized;
    renderCardStack();
  });
  document.getElementById('card-close')?.addEventListener('click', () => {
    pinnedCards.splice(currentCardIndex, 1);
    if (currentCardIndex >= pinnedCards.length) currentCardIndex = Math.max(0, pinnedCards.length - 1);
    renderCardStack();
  });

  // Copy buttons
  cardStack.querySelectorAll('.card-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const value = btn.dataset.value;
      try {
        await navigator.clipboard.writeText(value);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      } catch (err) {
        console.error('Copy failed:', err);
        btn.textContent = 'Failed';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      }
    });
  });

  // Trigger custom event for SMILES template extension
  cardStack.dispatchEvent(new CustomEvent('cardrendered', { detail: { idx, smilesValue } }));
}

// ============================================
// Export Panel System (multi-select)
// ============================================

const exportPanel = document.getElementById('export-panel');
const exportTitle = document.getElementById('export-title');
const exportColumns = document.getElementById('export-columns');
const exportCsvBtn = document.getElementById('export-csv');
const exportTsvBtn = document.getElementById('export-tsv');
const exportClearBtn = document.getElementById('export-clear');
const exportCloseBtn = document.getElementById('export-close');

let selectedIndices = [];

// Build column checkboxes
function buildExportColumns() {
  let html = '';
  for (const name of labelOptions) {
    const col = columns[name];
    if (!col) continue;
    html += '<label><input type="checkbox" value="' + name + '" checked> ' + name + '</label>';
  }
  exportColumns.innerHTML = html;
}
buildExportColumns();

function showExportPanel(indices) {
  selectedIndices = indices;
  exportTitle.textContent = indices.length.toLocaleString() + ' points selected';
  exportPanel.classList.remove('hidden');
}

function hideExportPanel() {
  selectedIndices = [];
  exportPanel.classList.add('hidden');
}

// Listen for scatterplot selection events (only show export for multi-select, not single click)
scatterplot.subscribe('select', (selection) => {
  const indices = selection.points || selection;
  if (Array.isArray(indices) && indices.length > 1) {
    showExportPanel(indices);
  } else {
    hideExportPanel();
  }
});

function getSelectedColumns() {
  const checked = [];
  exportColumns.querySelectorAll('input[type="checkbox"]:checked').forEach((cb) => {
    checked.push(cb.value);
  });
  return checked;
}

function exportData(separator, extension) {
  const colNames = getSelectedColumns();
  if (colNames.length === 0 || selectedIndices.length === 0) return;

  // Build header
  const rows = [colNames.join(separator)];

  // Build data rows
  for (const idx of selectedIndices) {
    const rowValues = colNames.map((name) => {
      const col = columns[name];
      if (!col) return '';
      const val = col.values[idx];
      let strVal = typeof val === 'number' ? formatValue(val) : String(val ?? '');
      // Escape quotes and wrap in quotes if contains separator or quotes
      if (strVal.includes(separator) || strVal.includes('"') || strVal.includes('\\n')) {
        strVal = '"' + strVal.replace(/"/g, '""') + '"';
      }
      return strVal;
    });
    rows.push(rowValues.join(separator));
  }

  const content = rows.join('\\n');
  const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
  const url = URL.createObjectURL(blob);

  const a = document.createElement('a');
  a.href = url;
  a.download = 'tmap_export_' + selectedIndices.length + '_points.' + extension;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

exportCsvBtn.addEventListener('click', () => exportData(',', 'csv'));
exportTsvBtn.addEventListener('click', () => exportData('\\t', 'tsv'));
exportClearBtn.addEventListener('click', () => {
  scatterplot.select([]);
  hideExportPanel();
});
exportCloseBtn.addEventListener('click', () => {
  hideExportPanel();
});

// Keyboard shortcut: Escape closes card stack and search
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if (pinnedCards.length > 0) {
      pinnedCards.length = 0;
      currentCardIndex = 0;
      renderCardStack();
    }
    // Also clear search
    if (searchMatches.length > 0) {
      clearSearch();
    }
  }
});

// ============================================
// Search System
// ============================================

const searchColumn = document.getElementById('search-column');
const searchInput = document.getElementById('search-input');
const searchBtn = document.getElementById('search-btn');
const clearSearchBtn = document.getElementById('clear-search');
const partialMatchCheckbox = document.getElementById('partial-match');
const searchResults = document.getElementById('search-results');

let searchMatches = [];

// Populate search column dropdown with string columns only
function buildSearchColumnOptions() {
  searchColumn.innerHTML = '';
  for (const name of labelOptions) {
    const col = columns[name];
    if (!col) continue;
    // Only include string columns (check first value)
    const firstVal = col.values[0];
    if (typeof firstVal !== 'string') continue;

    const opt = document.createElement('option');
    opt.value = name;
    opt.textContent = name;
    searchColumn.appendChild(opt);
  }
  // Add SMILES column if present and not already in labelOptions
  const smilesCol = metadata.smilesColumn;
  if (smilesCol && !labelOptions.includes(smilesCol)) {
    const col = columns[smilesCol];
    if (col && typeof col.values[0] === 'string') {
      const opt = document.createElement('option');
      opt.value = smilesCol;
      opt.textContent = smilesCol + ' (SMILES)';
      searchColumn.appendChild(opt);
    }
  }
}
buildSearchColumnOptions();

// Search function
function performSearch() {
  const colName = searchColumn.value;
  const query = searchInput.value.trim();
  const partial = partialMatchCheckbox.checked;

  if (!query || !colName) {
    searchResults.textContent = '';
    clearMarkers();
    return;
  }

  const col = columns[colName];
  if (!col) {
    searchResults.textContent = 'Column not found';
    return;
  }

  const matches = [];
  const queryLower = query.toLowerCase();

  for (let i = 0; i < col.values.length; i++) {
    const val = String(col.values[i] ?? '');
    const valLower = val.toLowerCase();

    if (partial) {
      if (valLower.includes(queryLower)) matches.push(i);
    } else {
      if (valLower === queryLower) matches.push(i);
    }
  }

  searchMatches = matches;

  if (matches.length === 0) {
    searchResults.textContent = 'No matches found';
    scatterplot.select([]);
  } else {
    searchResults.textContent = matches.length.toLocaleString() + ' match(es) found';
    scatterplot.select(matches);  // Highlights points and triggers export panel for 2+ matches
  }
}

function clearSearch() {
  searchInput.value = '';
  searchResults.textContent = '';
  searchMatches = [];
  scatterplot.select([]);
}

// Event handlers
searchBtn.addEventListener('click', performSearch);
searchInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') performSearch();
});
clearSearchBtn.addEventListener('click', clearSearch);

